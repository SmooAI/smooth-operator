{
    "name": "@smooai/smooth-operator",
    "version": "0.1.0",
    "description": "TypeScript protocol types and native WebSocket client for the smooth-operator protocol. Generated from the language-neutral JSON Schemas in spec/.",
    "license": "MIT",
    "type": "module",
    "engines": {
        "node": ">=22"
    },
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./validate": {
            "types": "./dist/validate.d.ts",
            "import": "./dist/validate.js"
        }
    },
    "files": [
        "dist",
        "src"
    ],
    "scripts": {
        "generate": "tsx scripts/generate.ts",
        "build": "tsc -p tsconfig.json",
        "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:e2e": "vitest run --config vitest.e2e.config.ts"
    },
    "dependencies": {
        "ajv": "^8.17.1",
        "ajv-formats": "^3.0.1"
    },
    "devDependencies": {
        "@apidevtools/json-schema-ref-parser": "^11.7.3",
        "@types/node": "^25.9.2",
        "json-schema-to-typescript": "^15.0.4",
        "tsx": "^4.19.2",
        "typescript": "^5.7.3",
        "vitest": "^2.1.8"
    }
}
