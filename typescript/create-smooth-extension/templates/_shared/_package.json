{
    "name": "__NAME__",
    "version": "0.1.0",
    "description": "A Smooth (SEP) extension.",
    "type": "module",
    "private": true,
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
        "start": "node dist/index.js",
        "test": "tsc -p tsconfig.json && vitest run"
    },
    "dependencies": {
        "@smooai/smooth-extension-sdk": "^0.5.0",
        "zod": "^4.0.0"
    },
    "devDependencies": {
        "@types/node": "^25.9.2",
        "typescript": "^5.7.3",
        "vitest": "^2.1.8"
    }
}
