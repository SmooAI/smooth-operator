# Copy to `.env` (or `.env.local`) and adjust. All are optional — the defaults
# target a local `cargo run -p smooai-smooth-operator-server` on port 8787.

# WebSocket endpoint of the smooth-operator server.
VITE_SMOOTH_WS_URL=ws://localhost:8787/ws

# Bearer token for a token-gated server (appended as ?token=). Leave unset for the
# local/no-auth reference server (connects anonymously; sees org-public knowledge).
# VITE_SMOOTH_TOKEN=

# Agent UUID to converse with. Defaults to a random one per page load, which the
# reference server accepts. Set this to talk to a specific configured agent.
# VITE_SMOOTH_AGENT_ID=
